# ============================================================
# FAIRWAY — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ---- SUPABASE ----
# From: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ---- JWT ----
# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here

# ---- APP ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# On Vercel: https://your-project.vercel.app

# NOTE: This project uses a mock payment system for demo purposes.
# No payment gateway API keys are required.
# The payment form collects card details but processes no real transactions.
